# Banco de dados (MVP usa SQLite local). Para produção, troque para PostgreSQL:
# DATABASE_URL="postgresql://usuario:senha@host:5432/alumy_pcp"
DATABASE_URL="file:./dev.db"

# Segredo da sessão (JWT). Em produção, gere um valor longo e aleatório:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="troque-este-segredo-em-producao-com-um-valor-aleatorio-longo"

# Senha inicial do usuário admin criado pelo seed (Nayla)
SEED_ADMIN_PASSWORD="alumy123"
